{
  "name": "obsidian-feishu",
  "version": "0.1.0",
  "description": "Sync Obsidian notes to Feishu/Lark documents",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "jest",
    "prebuild": "npm test",
    "test:e2e": "wdio run wdio.conf.ts",
    "test:e2e:prepare": "node node_modules/obsidian-launcher/bin/install-obsidian.js"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^16.11.6",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "esbuild": "0.25.5",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tslib": "2.4.0",
    "typescript": "^5.8.3",
    "wdio-obsidian-reporter": "^3.0.2",
    "wdio-obsidian-service": "^3.0.2",
    "webdriverio": "^9.27.0"
  },
  "dependencies": {
    "obsidian": "latest"
  }
}
